# Supabase Configuration
# Get these from your Supabase project dashboard or local dev
PUBLIC_SUPABASE_URL=http://localhost:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# For production, use your Supabase cloud project credentials
# PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key

# Stripe
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# RevenueCat (mobile IAP)
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# MapTiler (3D terrain viewer)
PUBLIC_MAPTILER_API_KEY=your-maptiler-api-key

# Sparrow (email — newsletter subscribe, transactional sends)
SPARROW_URL=https://sparrow-production-b53e.up.railway.app
SPARROW_API_KEY=sk_...

# Supabase database webhook secret (for /api/webhooks/user-signup)
SUPABASE_WEBHOOK_SECRET=your-random-secret
