{
  "expo": {
    "name": "SaltGoat",
    "slug": "saltgoat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saltgoat",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c1929"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saltgoat.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0c1929",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.saltgoat.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "react-native-maps",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SaltGoat uses your location to show your position on the map relative to Colorado 14ers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SaltGoat needs access to your photos to upload peak images.",
          "cameraPermission": "SaltGoat needs access to your camera to take peak photos."
        }
      ],
      "expo-sqlite",
      "expo-image",
      "react-native-purchases"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
