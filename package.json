{
  "name": "saltgoat",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "mobile"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:mobile": "npm run build --workspace=mobile",
    "build:all": "npm run build && npm run build:mobile",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.9.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.10.2",
    "@types/xmldom": "^0.1.34",
    "@vite-pwa/sveltekit": "^1.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.13.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "sharp": "^0.34.5",
    "svelte": "^5.14.1",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tmcw/togeojson": "^7.1.2",
    "@types/leaflet": "^1.9.21",
    "expo": "55.0.10-canary-20260328-2049187",
    "expo-apple-authentication": "55.0.10-canary-20260328-2049187",
    "expo-image-manipulator": "55.0.12-canary-20260328-2049187",
    "expo-image-picker": "55.0.15-canary-20260328-2049187",
    "isomorphic-dompurify": "^3.7.1",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.21.1",
    "marked": "^17.0.5",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "stripe": "^21.0.1",
    "xmldom": "^0.6.0"
  },
  "type": "module"
}
